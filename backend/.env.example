# ─── App ───
APP_ENV=development
DEBUG=true
APP_VERSION=1.0.0
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://goldenchicken:goldenchicken@localhost:5432/goldenchicken
DATABASE_URL_SYNC=postgresql+psycopg://goldenchicken:goldenchicken@localhost:5432/goldenchicken
POSTGRES_USER=goldenchicken
POSTGRES_PASSWORD=goldenchicken
POSTGRES_DB=goldenchicken

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Gemini AI ───
GEMINI_API_KEY=your-gemini-api-key
GEMINI_TEXT_MODEL=gemini-3-flash-preview
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LITE_MODEL=gemini-3.1-flash-lite-preview

# ─── RAG ───
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_TOP_K=10
RAG_RERANK_TOP_K=5

# ─── External APIs ───
OPENWEATHERMAP_API_KEY=your-owm-key
GOOGLE_MAPS_API_KEY=your-maps-key

# ─── S3 / MinIO ───
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=goldenchicken
S3_REGION=us-east-1

# ─── Firebase (Social Auth) ───
FIREBASE_PROJECT_ID=your-firebase-project

# ─── Live AI Guardrails ───
LIVE_AI_SESSION_MAX_MINUTES=10
LIVE_AI_DAILY_MAX_MINUTES=60
LIVE_AI_CONCURRENT_SESSIONS=1
LIVE_AI_DAILY_SPEND_CAP_USD=5.00

# ─── Market Scraping ───
MARKET_SCRAPING_ENABLED=true
MARKET_STALENESS_HOURS=24

# ─── Sentry ───
SENTRY_DSN=

# ─── Logging ───
LOG_LEVEL=INFO
LOG_FORMAT=json
